# NFE PropertyScope — Builder #2 standalone app
NEXT_PUBLIC_APP_NAME="NFE PropertyScope"
NEXT_PUBLIC_APP_ENV="local"
NEXT_PUBLIC_NFE_OS_ADAPTER_MODE="mock"

# Server-only Supabase connection for controlled-beta private evidence.
# Do not prefix the service-role credential with NEXT_PUBLIC_.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
PROPERTYSCOPE_PRIVATE_STORAGE_BUCKET="property-evidence"

# JSON object mapping invitation codes to fixed UUID tester identities.
# Example: {"MICHAEL-BETA":{"id":"00000000-0000-4000-8000-000000000001","name":"Michael"}}
PROPERTYSCOPE_BETA_TESTERS_JSON=""

# Optional public client variables for future authenticated Supabase use.
# Phase 1.2 upload routes do not require the browser to hold a service-role key.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Future APPROVED NFE-OS service boundary only.
# Do not point these values at the NFE-OS Platform UI/deployment as if it were an API.
NFE_OS_SERVICE_URL=""
NFE_OS_SERVICE_API_KEY=""

# Future visual provider
VISUAL_GENERATION_API_KEY=""
